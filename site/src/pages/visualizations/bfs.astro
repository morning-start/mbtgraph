---
import VizLayout from '../../components/VizLayout.astro';
import { resolveLegendItems } from '../../lib/color-registry';
import { legendKeys } from '../../lib/algs/bfs';
import { bfsGraph } from '../../lib/graph-data';

const legendItems = resolveLegendItems(legendKeys);
const subtitle = `${bfsGraph.nodes.length} 节点 · ${bfsGraph.edges.length} 边 · 无向图`;
---

<VizLayout
  title="BFS"
  {subtitle}
  hasStatusPanel={true}
  transportLeft={[{ action: 'skip-to-start' }, { action: 'step-back' }]}
  transportRight={[{ action: 'step-forward' }, { action: 'skip-to-end' }, { action: 'reset' }]}
  {legendItems}
>
  <div slot="status-panel">
    <div class="viz-status-item"><span class="viz-status-label">当前</span><span class="viz-status-value" id="current-node">—</span></div>
    <div class="viz-status-item"><span class="viz-status-label">访问顺序</span><span class="viz-status-mono" id="order">[ ]</span></div>
    <div class="viz-status-item"><span class="viz-status-label">队列</span><span class="viz-status-mono" id="queue">[ ]</span></div>
    <div class="viz-status-item"><span class="viz-status-label">层级</span><span class="viz-status-mono" id="levels">-</span></div>
  </div>

  <div slot="scripts">
    <script>
      import { VizApp } from '../../lib/viz-engine';
      import BFS from '../../lib/algs/bfs';
      import { bfsGraph } from '../../lib/graph-data';

      const initSubtitle = `${bfsGraph.nodes.length} 节点 · ${bfsGraph.edges.length} 边 · 无向图`;
      VizApp.init({
        algoInstance: BFS,
        title: "BFS 广度优先搜索",
        subtitle: initSubtitle,
        ...bfsGraph,
      });
    </script>
  </div>
</VizLayout>
