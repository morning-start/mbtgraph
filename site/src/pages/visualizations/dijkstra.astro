---
import VizLayout from '../../components/VizLayout.astro';
import { resolveLegendItems } from '../../lib/color-registry';
import { legendKeys } from '../../lib/algs/dijkstra';

const legendItems = resolveLegendItems(legendKeys);
---

<VizLayout
  title="Dijkstra 最短路径"
  subtitle="6 节点 · 9 边 · 带权有向图"
  hasStatusPanel={true}
  transportLeft={[{ action: 'reset' }, { action: 'step-back' }]}
  transportRight={[{ action: 'step-forward' }]}
  {legendItems}
>
  <div slot="status-panel">
    <div class="viz-status-item"><span class="viz-status-label">当前</span><span class="viz-status-value" id="current-node">—</span></div>
    <div class="viz-status-item"><span class="viz-status-label">距离</span><span class="viz-status-mono" id="dist-table">{}</span></div>
    <div class="viz-status-item"><span class="viz-status-label">已访问</span><span class="viz-status-mono" id="visited-nodes">[]</span></div>
  </div>

  <div slot="scripts">
    <script>
      import { VizApp } from '../../lib/viz-engine';
      import Dijkstra from '../../lib/algs/dijkstra';

      VizApp.init({
        algoInstance: Dijkstra,
        title: "Dijkstra 最短路径",
        subtitle: "6 节点 · 9 边 · 带权有向图",
        nodes: [{data:{id:'0',label:'0'}},{data:{id:'1',label:'1'}},{data:{id:'2',label:'2'}},{data:{id:'3',label:'3'}},{data:{id:'4',label:'4'}},{data:{id:'5',label:'5'}}],
        edges: [{data:{id:'e01',source:'0',target:'1',weight:4}},{data:{id:'e02',source:'0',target:'2',weight:2}},{data:{id:'e13',source:'1',target:'3',weight:5}},{data:{id:'e14',source:'1',target:'4',weight:10}},{data:{id:'e23',source:'2',target:'1',weight:1}},{data:{id:'e24',source:'2',target:'4',weight:8}},{data:{id:'e34',source:'3',target:'5',weight:2}},{data:{id:'e42',source:'4',target:'2',weight:7}},{data:{id:'e45',source:'4',target:'5',weight:3}}],
        startNode: '0',
      });
    </script>
  </div>
</VizLayout>
