---
import VizLayout from '../../components/VizLayout.astro';
import { resolveLegendItems } from '../../lib/color-registry';
import { legendKeys } from '../../lib/algs/cycle';

const legendItems = resolveLegendItems(legendKeys);
---

<VizLayout
  title="环检测"
  subtitle="7 节点 · 8 边 · 有向图"
  hasStatusPanel={true}
  transportLeft={[{ action: 'reset' }, { action: 'step-back' }]}
  transportRight={[{ action: 'step-forward' }]}
  {legendItems}
>
  <div slot="status-panel">
    <div class="viz-status-item"><span class="viz-status-label">当前</span><span class="viz-status-value" id="current-node">—</span></div>
    <div class="viz-status-item"><span class="viz-status-label">DFS 栈</span><span class="viz-status-mono" id="stack">[ ]</span></div>
    <div class="viz-status-item"><span class="viz-status-label">环状态</span><span class="viz-status-value" id="cycle">-</span></div>
  </div>

  <div slot="scripts">
    <script>
      import { VizApp } from '../../lib/viz-engine';
      import Cycle from '../../lib/algs/cycle';

      VizApp.init({
        algoInstance: Cycle,
        title: "DFS 环检测",
        subtitle: "7 节点 · 8 边 · 有向图",
        directed: true,
        nodes: [{data:{id:'0',label:'0'}},{data:{id:'1',label:'1'}},{data:{id:'2',label:'2'}},{data:{id:'3',label:'3'}},{data:{id:'4',label:'4'}},{data:{id:'5',label:'5'}},{data:{id:'6',label:'6'}}],
        edges: [{data:{id:'e01',source:'0',target:'1'}},{data:{id:'e12',source:'1',target:'2'}},{data:{id:'e20',source:'2',target:'0'}},{data:{id:'e13',source:'1',target:'3'}},{data:{id:'e34',source:'3',target:'4'}},{data:{id:'e45',source:'4',target:'5'}},{data:{id:'e56',source:'5',target:'6'}},{data:{id:'e36',source:'3',target:'6'}}],
      });
    </script>
  </div>
</VizLayout>
