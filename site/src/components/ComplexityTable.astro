---
/**
 * ComplexityTable.astro - 复杂度表格组件
 *
 * 用于展示算法的时间/空间复杂度对比表格，
 * 支持高亮最优值、添加说明注释等功能。
 */

interface Props {
  /** 表格数据 */
  data: Array<{
    algorithm: string;
    time?: string;
    space?: string;
    notes?: string;
    best?: boolean; // 是否标记为最佳选择
  }>;
  /** 表格标题 */
  title?: string;
  /** 是否显示时间复杂度列 */
  showTime?: boolean;
  /** 是否显示空间复杂度列 */
  showSpace?: boolean;
  /** 是否显示备注列 */
  showNotes?: boolean;
}

const {
  data,
  title,
  showTime = true,
  showSpace = true,
  showNotes = false,
} = Astro.props;
---

<div class="complexity-table-container">
  {title && <h3 class="table-title">{title}</h3>}

  <table class="complexity-table">
    <thead>
      <tr>
        <th>算法</th>
        {showTime && <th>时间复杂度</th>}
        {showSpace && <th>空间复杂度</th>}
        {showNotes && <th>备注</th>}
      </tr>
    </thead>
    <tbody>
      {data.map((row) => (
        <tr class={row.best ? 'best-choice' : ''}>
          <td class="algorithm-name">
            {row.algorithm}
            {row.best && <span class="best-badge">推荐</span>}
          </td>
          {showTime && <td class="complexity-value">{row.time || '-'}</td>}
          {showSpace && <td class="complexity-value">{row.space || '-'}</td>}
          {showNotes && <td class="notes">{row.notes || '-'}</td>}
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .complexity-table-container {
    margin: 1.5rem 0;
    overflow-x: auto;
  }

  .table-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--sl-color-text);
  }

  .complexity-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--sl-color-bg-secondary);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  thead {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }

  th {
    padding: 1rem;
    text-align: left;
    color: white;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  td {
    padding: 0.875rem 1rem;
    border-bottom: 1px solid var(--sl-color-border);
    color: var(--sl-color-text);
  }

  tbody tr {
    transition: background-color 0.2s;
  }

  tbody tr:hover {
    background-color: var(--sl-color-bg-tertiary);
  }

  tbody tr:last-child td {
    border-bottom: none;
  }

  .best-choice {
    background-color: rgba(16, 185, 129, 0.08);
  }

  .best-choice:hover {
    background-color: rgba(16, 185, 129, 0.15);
  }

  .algorithm-name {
    font-weight: 500;
    position: relative;
  }

  .best-badge {
    display: inline-block;
    margin-left: 0.5rem;
    padding: 0.15rem 0.5rem;
    background: #10b981;
    color: white;
    border-radius: 10px;
    font-size: 0.7rem;
    font-weight: 600;
    vertical-align: middle;
  }

  .complexity-value {
    font-family: 'Fira Code', 'Cascadia Code', Consolas, monospace;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--sl-color-text-accent);
  }

  .notes {
    font-size: 0.9rem;
    color: var(--sl-color-text-secondary);
  }

  /* 响应式设计 */
  @media (max-width: 768px) {
    .complexity-table {
      font-size: 0.85rem;
    }

    th, td {
      padding: 0.65rem 0.75rem;
    }
  }
</style>
