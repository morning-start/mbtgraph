---
/**
 * StorageSelector.astro - 存储结构选型器
 *
 * 交互式工具，帮助开发者根据使用场景选择最合适的图存储结构。
 * 通过问答引导、性能对比和代码示例，提供智能推荐。
 *
 * @features
 * - 场景化问答引导
 * - 动态推荐最佳存储方案
 * - 性能对比图表（时间/空间复杂度）
 * - 代码示例切换
 * - Trait 兼容性展示
 *
 * @example
 * ```astro
 * <StorageSelector />
 * ```
 */

interface Props {
  /** 额外的 CSS 类名 */
  class?: string;
}

const { class: className = '' } = Astro.props;

// 存储结构数据
const storageOptions = [
  {
    id: 'directed-adj-list',
    name: 'DirectedAdjList',
    label: '有向邻接表',
    category: '通用稀疏图',
    icon: '📊',
    traits: ['R', 'W', 'D', 'E'],
    timeComplexity: { addNode: 'O(1)', addEdge: 'O(1)', getNeighbors: 'O(k)' },
    spaceComplexity: 'O(V + E)',
    bestFor: ['通用场景', '动态图', '遍历操作'],
    description: '最通用的存储方式，支持完整的读写操作和有向图特性。',
    recommended: true,
  },
  {
    id: 'undirected-adj-list',
    name: 'UndirectedAdjList',
    label: '无向邻接表',
    category: '无向通用图',
    icon: '🔗',
    traits: ['R', 'W', 'E'],
    timeComplexity: { addNode: 'O(1)', addEdge: 'O(1)', getNeighbors: 'O(k)' },
    spaceComplexity: 'O(V + 2E)',
    bestFor: ['无向图', '社交网络', '节省空间'],
    description: '针对无向图优化，存储量减少约50%。',
    recommended: false,
  },
  {
    id: 'directed-matrix',
    name: 'DirectedMatrix',
    label: '邻接矩阵',
    category: '稠密小图',
    icon: '🔲',
    traits: ['R', 'W', 'D'],
    timeComplexity: { addNode: 'O(V²)', addEdge: 'O(1)', hasEdge: 'O(1)' },
    spaceComplexity: 'O(V²)',
    bestFor: ['稠密图', '快速边查询', '<1000节点'],
    description: '适合节点数较少的稠密图，边查询为 O(1)。',
    recommended: false,
  },
  {
    id: 'edge-list',
    name: 'EdgeList',
    label: '边集数组',
    category: 'MST/Kruskal',
    icon: '📋',
    traits: ['R', 'W', 'E'],
    timeComplexity: { addEdge: 'O(1)', getAllEdges: 'O(E log E)' },
    spaceComplexity: 'O(E)',
    bestFor: ['Kruskal算法', '最小生成树', '边排序操作'],
    description: '专为 Kruskal 等需要边排序的算法设计。',
    recommended: false,
  },
  {
    id: 'csr',
    name: 'CSR',
    label: '压缩稀疏行',
    category: '大规模静态图',
    icon: '⚡',
    traits: ['R', 'B'],
    timeComplexity: { getNeighbors: 'O(k)', iterateAll: 'O(V+E)' },
    spaceComplexity: 'O(V + E)',
    bestFor: ['>100K节点', '静态图', '缓存友好'],
    description: '大规模静态图的内存高效表示，缓存极其友好。',
    recommended: false,
  },
  {
    id: 'csc',
    name: 'CSC',
    label: '压缩稀疏列',
    category: '入度密集查询',
    icon: '🔄',
    traits: ['R', 'B'],
    timeComplexity: { inDegree: 'O(1)', getInEdges: 'O(k)' },
    spaceComplexity: 'O(V + E)',
    bestFor: ['反向查询', 'PageRank', '入度分析'],
    description: '专为频繁查询入边的场景设计。',
    recommended: false,
  },
];

// 场景问题
const scenarioQuestions = [
  {
    id: 'graph-type',
    question: '你的图是有向的还是无向的？',
    options: [
      { value: 'directed', label: '有向图', next: 'scale' },
      { value: 'undirected', label: '无向图', next: 'scale' },
      { value: 'both', label: '不确定/都有', next: 'scale' },
    ],
  },
  {
    id: 'scale',
    question: '图的规模大概是多少？',
    options: [
      { value: 'small', label: '小规模 (<1000 节点)', next: 'dynamic' },
      { value: 'medium', label: '中规模 (1K-100K 节点)', next: 'dynamic' },
      { value: 'large', label: '大规模 (>100K 节点)', next: 'operation' },
    ],
  },
  {
    id: 'dynamic',
    question: '图是否需要频繁增删节点或边？',
    options: [
      { value: 'yes', label: '是，需要动态修改', next: null, recommend: 'directed-adj-list' },
      { value: 'no', label: '否，基本是静态的', next: 'operation' },
    ],
  },
  {
    id: 'operation',
    question: '最常见的操作是什么？',
    options: [
      { value: 'traversal', label: '遍历邻居节点', next: null, recommend: 'directed-adj-list' },
      { value: 'edge-query', label: '查询两点间是否有边', next: null, recommend: 'directed-matrix' },
      { value: 'edge-sort', label: '按权重排序所有边', next: null, recommend: 'edge-list' },
      { value: 'in-degree', label: '查询节点的入度/入边', next: null, recommend: 'csc' },
      { value: 'batch-read', label: '批量读取（高性能）', next: null, recommend: 'csr' },
    ],
  },
];
---

<div class={`storage-selector ${className}`}>
  <div class="ss-header">
    <div class="header-content">
      <h3 class="ss-title">存储结构选择器</h3>
      <p class="ss-subtitle">回答几个问题，找到最适合你场景的存储方案</p>
    </div>
    <div class="ss-icon">🎯</div>
  </div>

  <div class="ss-body">
    <!-- 问答区域 -->
    <div class="quiz-section" id="quiz-section">
      <div class="question-container" id="question-container">
        {/* 问题将通过 JS 动态渲染 */}
        <div class="initial-prompt">
          <p>点击下方按钮开始选择流程</p>
          <button class="start-btn" id="start-quiz-btn">
            开始选型
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12,5 19,12 12,19"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- 进度指示 -->
      <div class="quiz-progress" id="quiz-progress" style="display: none;">
        <div class="progress-steps"></div>
      </div>

      <!-- 推荐结果 -->
      <div class="recommendation-result" id="recommendation-result" style="display: none;">
        <div class="result-header">
          <span class="result-label">推荐方案</span>
        </div>
        <div class="result-card" id="result-card">
          {/* 结果将通过 JS 填充 */}
        </div>
        <button class="restart-btn" id="restart-quiz-btn">重新选择</button>
      </div>
    </div>

    <!-- 分隔线 -->
    <div class="ss-divider">
      <span>或直接浏览所有选项</span>
    </div>

    <!-- 所有选项概览 -->
    <div class="options-grid">
      {storageOptions.map((option) => (
        <div
          class={`option-card ${option.recommended ? 'option-card--recommended' : ''}`}
          data-storage-id={option.id}
        >
          <div class="option-header">
            <span class="option-icon">{option.icon}</span>
            <div class="option-info">
              <h4 class="option-name">{option.name}</h4>
              <span class="option-category">{option.category}</span>
            </div>
            {option.recommended && (
              <span class="recommended-badge">推荐</span>
            )}
          </div>

          <p class="option-description">{option.description}</p>

          <!-- Trait 支持 -->
          <div class="traits-support">
            {option.traits.map((trait) => (
              <span class={`trait-tag trait-${trait.toLowerCase()}`} title={getTraitFullName(trait)}>
                {trait}
              </span>
            ))}
          </div>

          <!-- 复杂度信息 -->
          <div class="complexity-info">
            <div class="complexity-item">
              <span class="complexity-label">空间</span>
              <span class="complexity-value mono">{option.spaceComplexity}</span>
            </div>
            {Object.entries(option.timeComplexity).map(([op, complexity]) => (
              <div class="complexity-item">
                <span class="complexity-label">{formatOperationName(op)}</span>
                <span class="complexity-value mono">{complexity}</span>
              </div>
            ))}
          </div>

          <!-- 适用场景 -->
          <div class="use-cases">
            {option.bestFor.map((scenario) => (
              <span class="use-case-tag">{scenario}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<script define:vars={{ storageOptions, scenarioQuestions }}>
  function getTraitFullName(trait) {
    const map = {
      'R': 'GraphReadable (读取)',
      'W': 'GraphWritable (写入)',
      'D': 'GraphDirected (有向)',
      'B': 'GraphBatchReadable (批量)',
      'E': 'GraphEdgeIterable (边迭代)',
    };
    return map[trait] || trait;
  }

  function formatOperationName(op) {
    const map = {
      'addNode': '添加节点',
      'addEdge': '添加边',
      'getNeighbors': '获取邻居',
      'hasEdge': '查询边',
      'getAllEdges': '获取所有边',
      'inDegree': '入度查询',
      'getInEdges': '获取入边',
      'iterateAll': '遍历全部',
    };
    return map[op] || op;
  }

  // 初始化问答逻辑
  document.addEventListener('DOMContentLoaded', () => {
    const startBtn = document.getElementById('start-quiz-btn');
    const restartBtn = document.getElementById('restart-quiz-btn');
    const questionContainer = document.getElementById('question-container');
    const quizProgress = document.getElementById('quiz-progress');
    const recommendationResult = document.getElementById('recommendation-result');
    const resultCard = document.getElementById('result-card');

    let currentQuestionIndex = 0;
    let answers = {};

    function renderQuestion(index) {
      if (index >= scenarioQuestions.length) return;

      const question = scenarioQuestions[index];
      questionContainer.innerHTML = `
        <div class="question active">
          <div class="question-number">问题 ${index + 1}/${scenarioQuestions.length}</div>
          <h4 class="question-text">${question.question}</h4>
          <div class="options-list">
            ${question.options.map(opt => `
              <button class="option-btn" data-value="${opt.value}" data-next="${opt.next || ''}" data-recommend="${opt.recommend || ''}">
                ${opt.label}
                ${opt.next ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9,18 15,12 9,6"/></svg>' : ''}
              </button>
            `).join('')}
          </div>
        </div>
      `;

      // 绑定选项点击事件
      questionContainer.querySelectorAll('.option-btn').forEach(btn => {
        btn.addEventListener('click', () => handleAnswer(btn));
      });
    }

    function handleAnswer(btn) {
      const question = scenarioQuestions[currentQuestionIndex];
      const value = btn.dataset.value;
      const next = btn.dataset.next;
      const recommend = btn.dataset.recommend;

      answers[question.id] = value;

      if (recommend) {
        showRecommendation(recommend);
      } else if (next && currentQuestionIndex < scenarioQuestions.length - 1) {
        currentQuestionIndex++;
        updateProgress();
        renderQuestion(currentQuestionIndex);
      } else {
        // 默认推荐
        showRecommendation('directed-adj-list');
      }
    }

    function showRecommendation(storageId) {
      const option = storageOptions.find(o => o.id === storageId);
      if (!option) return;

      questionContainer.style.display = 'none';
      quizProgress.style.display = 'none';
      recommendationResult.style.display = 'block';

      const level = option.recommended ? 'excellent' : 'good';
      const levelConfig = {
        excellent: { color: '#10b981', bg: '#ecfdf5', text: '最佳匹配' },
        good: { color: '#06b6d4', bg: '#ecfeff', text: '推荐选择' },
      };
      const config = levelConfig[level];

      resultCard.innerHTML = `
        <div class="result-card-header" style="background: linear-gradient(135deg, ${config.bg}, white);">
          <div class="result-icon">${option.icon}</div>
          <div class="result-info">
            <h4 class="result-name">${option.name}</h4>
            <p class="result-label-text">${option.label}</p>
          </div>
          <span class="match-badge" style="background: ${config.color};">${config.text}</span>
        </div>
        <div class="result-body">
          <p>${option.description}</p>
          <div class="result-complexity">
            <strong>空间复杂度:</strong> <code>${option.spaceComplexity}</code>
          </div>
          <div class="result-traits">
            <strong>Trait 支持:</strong>
            ${option.traits.map(t => `<span class="mini-trait">${t}</span>`).join(' ')}
          </div>
        </div>
        <div class="result-footer">
          <a href="/core-concepts/storage-guide" class="view-details-link">查看详细文档 →</a>
        </div>
      `;
    }

    function updateProgress() {
      quizProgress.style.display = 'block';
      quizProgress.querySelector('.progress-steps').innerHTML =
        scenarioQuestions.map((_, i) =>
          `<div class="progress-dot ${i <= currentQuestionIndex ? 'active' : ''}"></div>`
        ).join('');
    }

    function resetQuiz() {
      currentQuestionIndex = 0;
      answers = {};
      questionContainer.style.display = 'block';
      questionContainer.innerHTML = `
        <div class="initial-prompt">
          <p>点击下方按钮开始选择流程</p>
          <button class="start-btn" id="start-quiz-btn">
            开始选型
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12,5 19,12 12,19"/>
            </svg>
          </button>
        </div>
      `;
      quizProgress.style.display = 'none';
      recommendationResult.style.display = 'none';

      // 重新绑定事件
      document.getElementById('start-quiz-btn')?.addEventListener('click', () => {
        currentQuestionIndex = 0;
        updateProgress();
        renderQuestion(0);
      });
    }

    startBtn?.addEventListener('click', () => {
      updateProgress();
      renderQuestion(0);
    });

    restartBtn?.addEventListener('click', resetQuiz);
  });
</script>

<style>
  .storage-selector {
    margin: var(--space-6) 0;
    background: var(--bg-base);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  /* ===== 头部 ===== */
  .ss-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-6);
    background: var(--gradient-primary);
    color: white;
  }

  .ss-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    margin: 0 0 var(--space-1) 0;
    color: white;
  }

  .ss-subtitle {
    margin: 0;
    opacity: 0.9;
    font-size: var(--text-sm);
  }

  .ss-icon {
    font-size: 2.5rem;
  }

  /* ===== 主体 ===== */
  .ss-body {
    padding: var(--space-6);
  }

  /* ===== 问答区域 ===== */
  .quiz-section {
    background: var(--bg-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .initial-prompt {
    text-align: center;
    padding: var(--space-8) var(--space-4);
  }

  .initial-prompt p {
    color: var(--text-secondary);
    margin-bottom: var(--space-4);
  }

  .start-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: var(--gradient-primary);
    color: white;
    border: none;
    border-radius: var(--radius-lg);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    cursor: pointer;
    transition: var(--transition-normal);
  }

  .start-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-primary);
  }

  .question {
    animation: fadeInUp 0.3s ease-out;
  }

  .question-number {
    font-size: var(--text-xs);
    color: var(--color-primary-500);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-2);
  }

  .question-text {
    font-size: var(--text-lg);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }

  .options-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .option-btn {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: var(--space-4) var(--space-5);
    background: var(--bg-base);
    border: 2px solid var(--border-default);
    border-radius: var(--radius-lg);
    cursor: pointer;
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    transition: var(--transition-fast);
    text-align: left;
  }

  .option-btn:hover {
    border-color: var(--color-primary-400);
    background: var(--color-primary-50);
    transform: translateX(8px);
    box-shadow: var(--shadow-md);
  }

  /* 进度 */
  .quiz-progress {
    display: flex;
    justify-content: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .progress-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--border-default);
    transition: var(--transition-fast);
  }

  .progress-dot.active {
    background: var(--color-primary-500);
    transform: scale(1.2);
  }

  /* 推荐结果 */
  .recommendation-result {
    animation: fadeInUp 0.4s ease-out;
  }

  .result-label {
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .result-card {
    background: var(--bg-base);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    margin-top: var(--space-3);
  }

  .result-card-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
  }

  .result-icon {
    font-size: 2rem;
  }

  .result-name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    margin: 0;
    color: var(--text-primary);
  }

  .result-label-text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0;
  }

  .match-badge {
    margin-left: auto;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    color: white;
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    text-transform: uppercase;
  }

  .result-body {
    padding: var(--space-4) var(--space-5);
  }

  .result-body p {
    margin-bottom: var(--space-3);
  }

  .result-complexity code {
    font-family: var(--font-mono);
    background: var(--color-primary-50);
    color: var(--color-primary-700);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }

  .mini-trait {
    display: inline-block;
    padding: 2px 6px;
    background: var(--bg-muted);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    font-family: var(--font-mono);
    color: var(--color-primary-600);
  }

  .result-footer {
    padding: var(--space-3) var(--space-5);
    background: var(--bg-subtle);
    border-top: 1px solid var(--border-default);
    text-align: right;
  }

  .view-details-link {
    color: var(--color-primary-500);
    font-weight: var(--font-medium);
    font-size: var(--text-sm);
    text-decoration: none;
  }

  .view-details-link:hover {
    color: var(--color-primary-700);
  }

  .restart-btn {
    margin-top: var(--space-4);
    padding: var(--space-2) var(--space-4);
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    cursor: pointer;
    font-size: var(--text-sm);
    transition: var(--transition-fast);
  }

  .restart-btn:hover {
    background: var(--bg-subtle);
    color: var(--text-primary);
  }

  /* ===== 分隔线 ===== */
  .ss-divider {
    position: relative;
    text-align: center;
    margin: var(--space-6) 0;
  }

  .ss-divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--border-default);
  }

  .ss-divider span {
    position: relative;
    background: var(--bg-base);
    padding: 0 var(--space-4);
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  /* ===== 选项网格 ===== */
  .options-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-4);
  }

  .option-card {
    background: var(--bg-base);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    transition: var(--transition-normal);
  }

  .option-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary-200);
  }

  .option-card--recommended {
    border-color: var(--color-success-500);
