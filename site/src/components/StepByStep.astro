---
/**
 * StepByStep.astro - 步骤分解组件
 *
 * 用于展示算法执行步骤、教程流程或任何分步说明。
 * 提供交互式导航和视觉引导，帮助用户理解复杂过程。
 *
 * @features
 * - 编号步骤卡片，支持标题、描述和详细内容
 * - 上一步/下一步导航按钮
 * - 当前步骤高亮显示
 * - 可折叠的详细信息面板
 * - 进度指示器
 * - 键盘导航支持（左右箭头键）
 *
 * @example
 * ```astro
 * <StepByStep
 *   title="Dijkstra 算法执行过程"
 *   steps={[
 *     {
 *       title: "初始化",
 *       summary: "设置起点距离为 0",
 *       detail: "创建距离数组...",
 *       code: "// 初始化代码"
 *     },
 *     {
 *       title: "选择最小距离节点",
 *       summary: "从未访问节点中选择",
 *       detail: "遍历所有未访问节点..."
 *     }
 *   ]}
 * />
 * ```
 */

interface Props {
  /** 组件标题 */
  title?: string;
  /** 步骤列表 */
  steps: Array<{
    /** 步骤标题 */
    title: string;
    /** 步骤摘要 */
    summary: string;
    /** 详细描述（可选） */
    detail?: string;
    /** 代码示例（可选） */
    code?: string;
    /** 是否为关键步骤 */
    highlight?: boolean;
    /** 警告信息 */
    warning?: string;
    /** 提示信息 */
    tip?: string;
  }>;
  /** 默认显示的步骤索引（从0开始） */
  initialStep?: number;
  /** 是否显示代码区域 */
  showCode?: boolean;
  /** 是否自动循环 */
  autoLoop?: boolean;
  /** 额外的 CSS 类名 */
  class?: string;
}

const {
  title,
  steps,
  initialStep = 0,
  showCode = true,
  autoLoop = false,
  class: className = '',
} = Astro.props;

const componentId = `stepbystep-${Math.random().toString(36).substring(2, 9)}`;
---

<div class={`step-by-step ${className}`} id={componentId}>
  {title && (
    <div class="sbs-header">
      <h3 class="sbs-title">{title}</h3>
      <div class="sbs-progress-info">
        <span class="current-step">步骤 {initialStep + 1}</span>
        <span class="step-separator">/</span>
        <span class="total-steps">{steps.length}</span>
      </div>
    </div>
  )}

  <!-- 进度条 -->
  <div class="progress-track">
    <div
      class="progress-bar"
      style={`width: ${((initialStep + 1) / steps.length) * 100}%`}
    ></div>
    {/* 步骤点 */}
    <div class="progress-dots">
      {steps.map((_, index) => (
        <button
          class={`dot ${index === initialStep ? 'dot--active' : ''} ${index < initialStep ? 'dot--completed' : ''}`}
          data-step={index}
          aria-label={`跳转到步骤 ${index + 1}`}
        ></button>
      ))}
    </div>
  </div>

  <!-- 主内容区 -->
  <div class="sbs-content">
    {steps.map((step, index) => (
      <div
        class={`step-card ${index === initialStep ? 'step-card--active' : ''} ${step.highlight ? 'step-card--highlight' : ''}`}
        data-step-index={index}
      >
        <div class="step-card-header">
          <div class="step-number-badge">
            <span class="step-number">{index + 1}</span>
            {step.highlight && (
              <span class="highlight-indicator" title="关键步骤">★</span>
            )}
          </div>
          <h4 class="step-title">{step.title}</h4>
          {step.warning && (
            <span class="warning-badge">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2L1 21h22L12 2zm0 3.99L19.53 19H4.47L12 5.99zM11 16h2v2h-2v-2zm0-6h2v4h-2v-4z"/>
              </svg>
              注意
            </span>
          )}
        </div>

        <p class="step-summary">{step.summary}</p>

        {(step.detail || step.code) && (
          <details class="step-details">
            <summary>查看详情</summary>
            <div class="details-content">
              {step.detail && (
                <p class="detail-text">{step.detail}</p>
              )}
              {step.tip && (
                <div class="tip-box">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="16" x2="12" y2="12"/>
                    <line x1="12" y1="8" x2="12.01" y2="8"/>
                  </svg>
                  <span>{step.tip}</span>
                </div>
              )}
              {showCode && step.code && (
                <pre class="detail-code"><code>{step.code}</code></pre>
              )}
            </div>
          </details>
        )}
      </div>
    ))}
  </div>

  <!-- 导航控制 -->
  <div class="sbs-navigation">
    <button
      class="nav-btn nav-btn--prev"
      data-direction="prev"
      disabled={initialStep === 0}
      aria-label="上一步"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="15,18 9,12 15,6"/>
      </svg>
      <span>上一步</span>
    </button>

    <div class="nav-center">
      <button class="reset-btn" data-action="reset" aria-label="重新开始">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="1,4 1,10 7,10"/>
          <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
        </svg>
      </button>
    </div>

    <button
      class="nav-btn nav-btn--next"
      data-direction="next"
      disabled={initialStep === steps.length - 1}
      aria-label="下一步"
    >
      <span>下一步</span>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="9,18 15,12 9,6"/>
      </svg>
    </button>
  </div>
</div>

<style>
  .step-by-step {
    margin: var(--space-6) 0;
    background: var(--bg-base);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  /* ===== 头部 ===== */
  .sbs-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-4) var(--space-6);
    background: linear-gradient(135deg, var(--color-primary-50) 0%, var(--bg-subtle) 100%);
    border-bottom: 1px solid var(--border-default);
  }

  .sbs-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin: 0;
  }

  .sbs-progress-info {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .current-step {
    font-weight: var(--font-bold);
    color: var(--color-primary-600);
  }

  /* ===== 进度条 ===== */
  .progress-track {
    position: relative;
    height: 4px;
    background: var(--bg-muted);
  }

  .progress-bar {
    height: 100%;
    background: var(--gradient-primary);
    transition: width var(--duration-slow) var(--ease-spring);
    border-radius: var(--radius-full);
  }

  .progress-dots {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    padding: 0 var(--space-4);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--border-default);
    border: 2px solid transparent;
    cursor: pointer;
    transition: var(--transition-fast);
    position: relative;
    z-index: 1;
  }

  .dot:hover {
    transform: scale(1.2);
    background: var(--color-primary-300);
  }

  .dot--active {
    background: var(--color-primary-500);
    transform: scale(1.3);
    box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.2);
  }

  .dot--completed {
    background: var(--color-success-500);
  }

  /* ===== 内容区 ===== */
  .sbs-content {
    position: relative;
    min-height: 200px;
    padding: var(--space-6);
  }

  .step-card {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateX(20px);
    transition: all var(--duration-slow) var(--ease-in-out);
    padding: 0 var(--space-6);
  }

  .step-card--active {
    position: relative;
    opacity: 1;
    visibility: visible;
    transform: translateX(0);
  }

  .step-card--highlight {
    background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
    border-left: 4px solid var(--color-warning-500);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    margin: calc(var(--space-4) * -1);
  }

  .step-card-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .step-number-badge {
    position: relative;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--gradient-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: var(--font-bold);
    font-size: var(--text-lg);
    box-shadow: var(--shadow-md);
    flex-shrink: 0;
  }

  .highlight-indicator {
    position: absolute;
    top: -4px;
    right: -4px;
    font-size: var(--text-xs);
    color: var(--color-warning-500);
  }

  .step-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin: 0;
  }

  .warning-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    margin-left: auto;
    padding: var(--space-1) var(--space-2);
    background: var(--color-danger-50);
    color: var(--color-danger-600);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
  }

  .step-summary {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  /* ===== 详情折叠 ===== */
  .step-details {
    margin-top: var(--space-4);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .step-details summary {
    padding: var(--space-3) var(--space-4);
    background: var(--bg-subtle);
    cursor: pointer;
    font-weight: var(--font-medium);
    color: var(--color-primary-600);
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .step-details summary::before {
    content: '▶';
    font-size: 0.7em;
    transition: transform var(--duration-fast);
  }

  .step-details[open] summary::before {
    transform: rotate(90deg);
  }

  .details-content {
    padding: var(--space-4);
    border-top: 1px solid var(--border-default);
  }

  .detail-text {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-3);
  }

  .tip-box {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-3);
    background: var(--color-info-50);
    border-left: 3px solid var(--color-info-500);
    border-radius: var(--radius-md);
    color: var(--color-info-600);
    font-size: var(--text-sm);
    margin-bottom: var(--space-3);
  }

  .detail-code {
    margin: var(--space-3) 0 0;
    padding: var(--space-4);
    background: var(--color-gray-900);
    border-radius: var(--radius-md);
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .detail-code code {
    color: #e5e7eb;
  }

  /* ===== 导航栏 ===== */
  .sbs-navigation {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-4) var(--space-6);
    background: var(--bg-subtle);
    border-top: 1px solid var(--border-default);
    gap: var(--space-4);
  }

  .nav-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    background: var(--bg-base);
    color: var(--text-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    cursor: pointer;
    font-weight: var(--font-medium);
    font-size: var(--text-sm);
    transition: var(--transition-normal);
  }

  .nav-btn:hover:not(:disabled) {
    background: var(--color-primary-50);
    color: var(--color-primary-600);
    border-color: var(--color-primary-300);
    transform: translateX(var(--translate-x, 0));
  }

  .nav-btn--prev:hover:not(:disabled) {
    --translate-x: -4px;
  }

  .nav-btn--next:hover:not(:disabled) {
    --translate-x: 4px;
  }

  .nav-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .nav-center {
    display: flex;
    align-items: center;
  }

  .reset-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--bg-muted);
    color: var(--text-muted);
    border: 1px solid var(--border-default);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-fast);
  }

  .reset-btn:hover {
    background: var(--color-primary-50);
    color: var(--color-primary-600);
    border-color: var(--color-primary-300);
    transform: rotate(-180deg);
  }

  /* ===== 响应式 ===== */
  @media (max-width: 768px) {
    .sbs-header {
      flex-direction: column;
      gap: var(--space-2);
      align-items: flex-start;
    }

    .sbs-content {
      min-height: 250px;
      padding: var(--space-4);
    }

    .step-card {
      padding: 0;
    }

    .step-number-badge {
      width: 32px;
      height: 32px;
      font-size: var(--text-base);
    }

    .step-title {
      font-size: var(--text-lg);
    }

    .nav-btn span {
      display: none; /* 移动端只显示箭头 */
    }

    .nav-btn {
      padding: var(--space-3);
    }
  }
</style>

<script define:vars={{ componentId, totalSteps: steps.length }}>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById(componentId);
    if (!container) return;

    let currentStep = parseInt(container.querySelector('.current-step')?.textContent?.match(/\d+/)?.[0] || '1') - 1;
    const cards = container.querySelectorAll('.step-card');
    const dots = container.querySelectorAll('.dot');
    const prevBtn = container.querySelector('.nav-btn--prev');
    const nextBtn = container.querySelector('.nav-btn--next');
    const resetBtn = container.querySelector('.reset-btn');
    const progressBar = container.querySelector('.progress-bar');
    const currentStepEl = container.querySelector('.current-step');

    function updateUI() {
      // 更新卡片可见性
      cards.forEach((card, index) => {
        card.classList.toggle('step-card--active', index === currentStep);
      });

      // 更新点状态
      dots.forEach((dot, index) => {
        dot.classList.remove('dot--active', 'dot--completed');
        if (index === currentStep) dot.classList.add('dot--active');
        else if (index < currentStep) dot.classList.add('dot--completed');
      });

      // 更新进度条
      if (progressBar) {
        progressBar.style.width = `${((currentStep + 1) / totalSteps) * 100}%`;
      }

      // 更新步骤数字
      if (currentStepEl) {
        currentStepEl.textContent = `步骤 ${currentStep + 1}`;
      }

      // 更新按钮状态
      if (prevBtn) prevBtn.disabled = currentStep === 0;
      if (nextBtn) nextBtn.disabled = currentStep === totalSteps - 1;
    }

    function goToStep(index) {
      if (index >= 0 && index < totalSteps) {
        currentStep = index;
        updateUI();
      }
    }

    // 导航按钮事件
    prevBtn?.addEventListener('click', () => goToStep(currentStep - 1));
    nextBtn?.addEventListener('click', () => goToStep(currentStep + 1));
    resetBtn?.addEventListener('click', () => goToStep(0));

    // 点击进度点
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => goToStep(index));
    });

    // 键盘导航
    container.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') goToStep(currentStep + 1);
      else if (e.key === 'ArrowLeft') goToStep(currentStep - 1);
    });

    // 使容器可聚焦以接收键盘事件
    container.setAttribute('tabindex', '0');
  });
</script>
