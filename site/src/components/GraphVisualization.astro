---
/**
 * GraphVisualization.astro - 交互式图算法可视化组件（Cytoscape.js 封装）
 *
 * 基于 Cytoscape.js 实现的 VisuAlgo 风格交互式算法动画组件。
 * 支持 BFS/DFS 等图遍历算法的分步可视化演示。
 *
 * @features
 * - Cytoscape.js Canvas 渲染，支持缩放、拖拽、节点选择
 * - 步骤化动画引擎：Play/Pause/Step Forward/Step Back/Reset
 * - 速度调节滑块 (1x ~ 10x)
 * - 实时状态面板：当前步骤、队列、访问顺序、层级信息
 * - VisuAlgo 配色方案：灰色(默认) → 橙色(处理中) → 绿色(已完成) → 红色(树边)
 * - 键盘快捷键支持：Space/←/→/R
 *
 * @example
 * ```astro
 * <GraphVisualization
 *   algorithm="bfs"
 *   startNode="0"
 *   :nodes="[{id:'0',label:'0'},{id:'1',label:'1'},...]"
 *   :edges="[{source:'0',target:'1'},{source:'0',target:'4'},...]"
 * />
 * ```
 */

interface Props {
  /** 图节点定义 */
  nodes: Array<{
    id: string
    label?: string
    position?: { x: number; y: number }
  }>
  /** 图边定义 */
  edges: Array<{
    source: string
    target: string
    label?: string
    weight?: number
  }>
  /** 要运行的算法 */
  algorithm?: 'bfs'
  /** 算法起点节点 ID */
  startNode?: string
  /** 布局算法 */
  layout?: 'dagre' | 'cola' | 'breadthfirst' | 'circle' | 'grid'
  /** 是否显示控制栏（默认 true） */
  showControls?: boolean
  /** 是否显示状态面板（默认 true） */
  showStatusPanel?: boolean
  /** 容器最大高度 */
  maxHeight?: string
  /** 额外 CSS 类名 */
  class?: string
}

const {
  nodes,
  edges,
  algorithm = 'bfs',
  startNode = '0',
  layout = 'dagre',
  showControls = true,
  showStatusPanel = true,
  maxHeight = '480px',
  class: className = '',
} = Astro.props

// 生成唯一组件 ID
const vizId = `gviz-${Math.random().toString(36).substring(2, 9)}`
---

<div
  class:list={['graph-viz-wrapper', className]}
  data-viz-id={vizId}
  data-algorithm={algorithm}
  data-start-node={startNode}
  data-layout={layout}
>
  <!-- 头部信息栏 -->
  <div class="gv-header">
    <div class="gv-header-left">
      <span class="gv-algorithm-badge">
        {algorithm === 'bfs' ? 'BFS 广度优先搜索' : algorithm.toUpperCase()}
      </span>
      <span class="gv-graph-info">{nodes.length} 节点 · {edges.length} 边</span>
    </div>
    <div class="gv-header-right">
      <span class="gv-hint">可拖拽 / 滚轮缩放</span>
    </div>
  </div>

  <!-- 图画布区域 -->
  <div class="gv-canvas-wrap" style={`max-height: ${maxHeight};`}>
    <div id={`${vizId}-canvas`} class="gv-canvas"></div>

    <!-- 当前步骤浮层提示 -->
    <div class="gv-step-tooltip" id={`${vizId}-tooltip`} hidden>
      <span class="tooltip-text"></span>
    </div>
  </div>

  <!-- 控制栏 -->
  {showControls && (
    <div class="gv-controls" id={`${vizId}-controls`}>
      <div class="gv-controls-left">
        <button class="gv-btn gv-btn--icon" data-action="skip-to-start" title="跳到开始 (Home)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 41l9-9-9-9h-6l7 7H3v4h17l-7 7zM6 19l-9 9 9 9h6l-7-7H21v-4H5l7-7z"/></svg>
        </button>
        <button class="gv-btn gv-btn--icon" data-action="step-back" title="上一步 (←)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
        </button>
        <button class="gv-btn gv-btn--primary" data-action="toggle-play" title="播放/暂停 (Space)">
          <svg class="icon-play" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          <svg class="icon-pause hidden" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
        </button>
        <button class="gv-btn gv-btn--icon" data-action="step-forward" title="下一步 (→)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
        </button>
        <button class="gv-btn gv-btn--icon" data-action="skip-to-end" title="跳到末尾 (End)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6 18l8-8-8-8v16zm2-3.5L13.5 10 8 5.5v9z"/></svg>
        </button>
      </div>

      <div class="gv-controls-center">
        <div class="gv-progress-track">
          <div class="gv-progress-fill" id={`${vizId}-progress`}></div>
          <div class="gv-progress-thumb" id={`${vizId}-thumb`}></div>
        </div>
        <span class="gv-step-counter" id={`${vizId}-counter`}>0 / 0</span>
      </div>

      <div class="gv-controls-right">
        <div class="gv-speed-control">
          <label for={`${vizId}-speed`}>速度:</label>
          <input type="range" id={`${vizId}-speed`} min="1" max="10" value="5" step="1" class="gv-speed-slider" />
          <span class="gv-speed-value" id={`${vizId}-speed-val`}>5x</span>
        </div>
        <button class="gv-btn gv-btn--icon" data-action="reset" title="重置 (R)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1,4 1,10 7,10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
        </button>
      </div>
    </div>
  )}

  <!-- 状态信息面板 -->
  {showStatusPanel && (
    <div class="gv-status-panel" id={`${vizId}-status`}>
      <div class="gv-status-grid">
        <div class="gv-status-item">
          <span class="gv-status-label">当前步骤</span>
          <span class="gv-status-value" id={`${vizId}-msg`}>准备就绪</span>
        </div>
        <div class="gv-status-item">
          <span class="gv-status-label">访问顺序</span>
          <span class="gv-status-value gv-status--mono" id={`${vizId}-order`}>[ ]</span>
        </div>
        <div class="gv-status-item">
          <span class="gv-status-label">队列</span>
          <span class="gv-status-value gv-status--mono" id={`${vizId}-queue`}>[ ]</span>
        </div>
        <div class="gv-status-item">
          <span class="gv-status-label">层级分布</span>
          <span class="gv-status-value" id={`${vizId}-levels`}>-</span>
        </div>
      </div>
    </div>
  )}

  <!-- 图例 -->
  <div class="gv-legend">
    <span class="legend-item"><i class="dot dot-default"></i> 未访问</span>
    <span class="legend-item"><i class="dot dot-active"></i> 处理中</span>
    <span class="legend-item"><i class="dot dot-visited"></i> 已完成</span>
    <span class="legend-item"><i class="line line-tree"></i> 树边</span>
    <span class="legend-item"><i class="line line-cross"></i> 已检查</span>
  </div>
</div>

<script define:vars={{ vizId, nodes, edges, algorithm, startNode, layout }}>
  // ============================================================
  // Cytoscape.js + 动画引擎 - 完整客户端逻辑
  // ============================================================

  import cytoscape from 'cytoscape'
  import dagre from 'cytoscape-dagre'

  // 注册 dagre 布局扩展
  cytoscape.use(dagre)

  // ============================================================
  // 类型定义
  // ============================================================

  interface GraphNode {
    id: string
    label: string
  }

  interface GraphEdge {
    source: string
    target: string
  }

  interface AnimStep {
    type: 'init' | 'dequeue' | 'visit_node' | 'visit_edge' | 'skip_edge' | 'enqueue' | 'finish'
    targets: string[]
    message: string
    order?: string[]
    queue?: string[]
    levels?: Record<string, number>
  }

  // ============================================================
  // BFS 动画步骤生成器
  // ============================================================

  function generateBFSSteps(
    nodeList: GraphNode[],
    edgeList: GraphEdge[],
    startId: string
  ): AnimStep[] {
    const steps: AnimStep[] = []

    // 构建邻接表
    const adjList = new Map<string, string[]>()
    for (const n of nodeList) {
      adjList.set(n.id, [])
    }
    for (const e of edgeList) {
      adjList.get(e.source)?.push(e.target)
      adjList.get(e.target)?.push(e.source) // 无向图
    }

    const visited = new Set<string>()
    const queue: string[] = [startId]
    const order: string[] = []
    const levels: Record<string, number> = {}
    levels[startId] = 0

    steps.push({
      type: 'init',
      targets: [startId],
      message: `初始化: 起点 ${startId} 入队`,
      order: [...order],
      queue: [...queue],
      levels: { ...levels },
    })

    let head = 0
    while (head < queue.length) {
      const current = queue[head]
      head++

      if (!visited.has(current)) {
        visited.add(current)
        order.push(current)

        steps.push({
          type: 'dequeue',
          targets: [current],
          message: `出队: 节点 ${current}`,
          order: [...order],
          queue: queue.slice(head).map(n => n),
          levels: { ...levels },
        })

        const neighbors = adjList.get(current) || []
        for (const nbr of neighbors) {
          if (!visited.has(nbr)) {
            visited.add(nbr)
            queue.push(nbr)
            levels[nbr] = (levels[current] ?? 0) + 1

            steps.push({
              type: 'visit_edge',
              targets: [current, nbr],
              message: `发现新节点 ${nbr}! 入队 (Level ${levels[nbr]})`,
              order: [...order],
              queue: queue.slice(head).map(n => n),
              levels: { ...levels },
            })
          } else {
            steps.push({
              type: 'skip_edge',
              targets: [current, nbr],
              message: `${nbr} 已访问, 跳过`,
              order: [...order],
              queue: queue.slice(head).map(n => n),
              levels: { ...levels },
            })
          }
        }

        steps.push({
          type: 'visit_node',
          targets: [current],
          message: `${current} 处理完毕 ✓`,
          order: [...order],
          queue: queue.slice(head).map(n => n),
          levels: { ...levels },
        })
      } else {
        steps.push({
          type: 'skip_edge',
          targets: [current],
          message: `${current} 已在队列中, 跳过`,
          order: [...order],
          queue: queue.slice(head).map(n => n),
          levels: { ...levels },
        })
      }
    }

    steps.push({
      type: 'finish',
      targets: [],
      message: `✅ BFS 完成! 访问顺序: [${order.join(', ')}]`,
      order: [...order],
      queue: [],
      levels: { ...levels },
    })

    return steps
  }

  // ============================================================
  // 动画引擎类
  // ============================================================

  class GraphAnimationEngine {
    private cy: cytoscape.Core
    private steps: AnimStep[]
    private currentIdx: number = -1
    private isPlaying: boolean = false
    private speed: number = 500 // ms per step
    private timerId: ReturnType<typeof setTimeout> | null = null

    // DOM 元素缓存
    private playBtn: HTMLElement
    private iconPlay: HTMLElement
    private iconPause: HTMLElement
    private progressBar: HTMLElement
    private progressFill: HTMLElement
    private thumbEl: HTMLElement
    private counterEl: HTMLElement
    private msgEl: HTMLElement
    private orderEl: HTMLElement
    private queueEl: HTMLElement
    private levelsEl: HTMLElement
    private tooltipEl: HTMLElement
    private speedSlider: HTMLInputElement
    private speedValEl: HTMLElement
    private controlsEl: HTMLElement

    constructor(cy: cytoscape.Core, steps: AnimStep[], containerId: string) {
      this.cy = cy
      this.steps = steps

      const wrap = document.querySelector(`[data-viz-id="${containerId}"]`)
      if (!wrap) return

      this.playBtn = wrap.querySelector('[data-action="toggle-play"]')!
      this.iconPlay = wrap.querySelector('.icon-play')!
      this.iconPause = wrap.querySelector('.icon-pause')!
      this.progressBar = wrap.querySelector('.gv-progress-track')!
      this.progressFill = wrap.querySelector('.gv-progress-fill')!
      this.thumbEl = wrap.querySelector('.gv-progress-thumb')!
      this.counterEl = wrap.querySelector(`#${containerId}-counter`)!
      this.msgEl = wrap.querySelector(`#${containerId}-msg`)!
      this.orderEl = wrap.querySelector(`#${containerId}-order`)!
      this.queueEl = wrap.querySelector(`#${containerId}-queue`)!
      this.levelsEl = wrap.querySelector(`#${containerId}-levels`)!
      this.tooltipEl = wrap.querySelector(`#${containerId}-tooltip`)!
      this.speedSlider = wrap.querySelector(`#${containerId}-speed`) as HTMLInputElement
      this.speedValEl = wrap.querySelector(`#${containerId}-speed-val`)!
      this.controlsEl = wrap.querySelector(`#${containerId}-controls`)!

      this.bindEvents()
      this.updateUI()
    }

    private bindEvents() {
      // 控制按钮
      this.playBtn?.addEventListener('click', () => this.togglePlay())

      const getBtn = (action: string) =>
        this.controlsEl?.querySelector(`[data-action="${action}"]`)

      getBtn('step-forward')?.addEventListener('click', () => this.stepForward())
      getBtn('step-back')?.addEventListener('click', () => this.stepBack())
      getBtn('skip-to-start')?.addEventListener('click', () => this.skipToStart())
      getBtn('skip-to-end')?.addEventListener('click', () => this.skipToEnd())
      getBtn('reset')?.addEventListener('click', () => this.reset())

      // 速度调节
      this.speedSlider?.addEventListener('input', (e) => {
        const val = parseInt((e.target as HTMLInputElement).value)
        this.speed = Math.max(50, 1100 - val * 100) // 1=1000ms, 10=100ms
        this.speedValEl!.textContent = `${val}x`
      })

      // 进度条点击跳转
      this.progressBar?.addEventListener('click', (e) => {
        const rect = this.progressBar!.getBoundingClientRect()
        const pct = (e.clientX - rect.left) / rect.width
        const targetIdx = Math.round(pct * (this.steps.length - 1))
        this.jumpTo(targetIdx)
      })

      // 键盘快捷键
      const wrap = this.controlsEl?.closest('.graph-viz-wrapper')
      wrap?.setAttribute('tabindex', '0')
      wrap?.addEventListener('keydown', (e: KeyboardEvent) => {
        switch (e.key) {
          case ' ': e.preventDefault(); this.togglePlay(); break
          case 'ArrowRight': e.preventDefault(); this.stepForward(); break
          case 'ArrowLeft': e.preventDefault(); this.stepBack(); break
          case 'Home': e.preventDefault(); this.skipToStart(); break
          case 'End': e.preventDefault(); this.skipToEnd(); break
          case 'r':
          case 'R':
            if (!e.ctrlKey && !e.metaKey) { e.preventDefault(); this.reset() }
            break
        }
      })
    }

    togglePlay() {
      if (this.isPlaying) {
        this.pause()
      } else {
        this.play()
      }
    }

    play() {
      if (this.currentIdx >= this.steps.length - 1) {
        this.jumpTo(0)
      }
      this.isPlaying = true
      this.updatePlayButton()
      this.tick()
    }

    pause() {
      this.isPlaying = false
      if (this.timerId) {
        clearTimeout(this.timerId)
        this.timerId = null
      }
      this.updatePlayButton()
    }

    private tick() {
      if (!this.isPlaying) return
      if (this.currentIdx < this.steps.length - 1) {
        this.stepForward()
        this.timerId = setTimeout(() => this.tick(), this.speed)
      } else {
        this.pause()
      }
    }

    stepForward() {
      if (this.currentIdx < this.steps.length - 1) {
        this.currentIdx++
        this.executeStep(this.steps[this.currentIdx])
        this.updateUI()
      }
    }

    stepBack() {
      if (this.currentIdx > 0) {
        // 回退时需要重绘到该步骤的状态
        this.currentIdx--
        this.rebuildTo(this.currentIdx)
        this.updateUI()
      }
    }

    skipToStart() {
      this.pause()
      this.jumpTo(0)
    }

    skipToEnd() {
      this.pause()
      this.jumpTo(this.steps.length - 1)
    }

    jumpTo(idx: number) {
      idx = Math.max(0, Math.min(idx, this.steps.length - 1))
      this.currentIdx = idx
      this.rebuildTo(idx)
      this.updateUI()
    }

    reset() {
      this.pause()
      this.currentIdx = -1
      this.resetVisuals()
      this.updateUI()
    }

    private executeStep(step: AnimStep) {
      const duration = Math.max(200, this.speed * 0.6)

      switch (step.type) {
        case 'init': {
          const node = this.cy.getElementById(step.targets[0])
          node.animate({
            style: {
              'background-color': '#B45309',     // 深棕色 - 起点
              'border-color': '#92400E',
              'border-width': 4,
              'width': 48,
              'height': 48,
            },
          }, { duration })
          this.showTooltip(step.targets[0], `起点\n${step.message}`)
          break
        }

        case 'dequeue': {
          const node = this.cy.getElementById(step.targets[0])
          node.animate({
            style: {
              'background-color': '#F97316',     // 橙色 - 正在处理
              'border-color': '#EA580C',
              'border-width': 3,
              'width': 46,
              'height': 46,
            },
          }, { duration })
          break
        }

        case 'visit_node': {
          const node = this.cy.getElementById(step.targets[0])
          node.animate({
            style: {
              'background-color': '#22C55E',     // 绿色 - 已完成
              'border-color': '#16A34A',
              'border-width': 2,
              'width': 40,
              'height': 40,
            },
          }, { duration })
          this.hideTooltip()
          break
        }

        case 'visit_edge': {
          const [src, tgt] = step.targets
          // 高亮边 - 树边红色
          const edge = this.cy.edges(
            `[source = "${src}"][target = "${tgt}"], [source = "${tgt}"][target = "${src}"]`
          )
          edge.animate(
            {
              style: {
                'line-color': '#EF4444',
                'target-arrow-color': '#EF4444',
                'source-arrow-color': '#EF4444',
                'width': 3.5,
                'opacity': 1,
              },
            },
            { duration }
          )

          // 新发现的节点闪烁一下
          const newNode = this.cy.getElementById(tgt)
          newNode.animate(
            {
              style: {
                'background-color': '#FBBF24',   // 黄色 - 刚发现
                'border-color': '#F59E0B',
                'border-width': 3,
              },
            },
            { duration: duration * 0.5 }
          )
          break
        }

        case 'skip_edge': {
          const [src, tgt] = step.targets
          const edge = this.cy.edges(
            `[source = "${src}"][target = "${tgt}"], [source = "${tgt}"][target = "${src}"]`
          )
          edge.animate(
            {
              style: {
                'line-color': '#94A3B8',         // 灰色虚线 - 已跳过
                'target-arrow-color': '#94A3B8',
                'source-arrow-color': '#94A3B8',
                'width': 1.5,
                'line-style': 'dashed',
                'opacity': 0.5,
              },
            },
            { duration: duration * 0.5 }
          )
          break
        }

        case 'finish': {
          // 所有已完成节点最终确认绿色
          this.cy.nodes().animate(
            {
              style: {
                'background-color': (ele: any) => {
                  return ele.data('id') === startNode ? '#B45309' : '#22C55E'
                },
              },
            },
            { duration: 400 }
          )
          break
        }
      }
    }

    // 从头重建到指定步骤的所有视觉状态
    private rebuildTo(targetIdx: number) {
      this.resetVisuals()

      // 快速重放到目标步骤（不播放动画，直接设最终状态）
      for (let i = 0; i <= targetIdx; i++) {
        const step = this.steps[i]
        if (!step) continue

        switch (step.type) {
          case 'init': {
            this.cy.getElementById(step.targets[0]).style({
              'background-color': '#B45309',
              'border-color': '#92400E',
              'border-width': 4,
              'width': 48, 'height': 48,
            })
            break
          }
          case 'dequeue': {
            this.cy.getElementById(step.targets[0]).style({
              'background-color': '#F97316',
              'border-color': '#EA580C',
              'border-width': 3,
            })
            break
          }
          case 'visit_node': {
            this.cy.getElementById(step.targets[0]).style({
              'background-color': '#22C55E',
              'border-color': '#16A34A',
              'border-width': 2,
            })
            break
          }
          case 'visit_edge': {
            const [src, tgt] = step.targets
            this.cy.edges(`[source = "${src}"][target = "${tgt}"], [source = "${tgt}"][target = "${src}"]`).style({
              'line-color': '#EF4444', 'target-arrow-color': '#EF4444', 'source-arrow-color': '#EF4444',
              'width': 3.5,
            })
            this.cy.getElementById(tgt).style({ 'background-color': '#FBBF24', 'border-color': '#F59E0B' })
            break
          }
          case 'skip_edge': {
            const [src, tgt] = step.targets
            this.cy.edges(`[source = "${src}"][target = "${tgt}"], [source = "${tgt}"][target = "${src}"]`).style({
              'line-color': '#94A3B8', 'target-arrow-color': '#94A3B8', 'source-arrow-color': '#94A3B8',
              'width': 1.5, 'line-style': 'dashed', 'opacity': 0.5,
            })
            break
          }
        }
      }
    }

    private resetVisuals() {
      // 重置所有节点为默认样式
      this.cy.nodes().style({
        'background-color': '#374151',
        'border-color': '#4B5563',
        'border-width': 2,
        'color': '#fff',
        'width': 40,
        'height': 40,
        'font-size': '14px',
        'text-valign': 'center',
        'text-halign': 'center',
        'label': 'data(label)',
      })

      // 重置所有边为默认样式
      this.cy.edges().style({
        'line-color': '#6B7280',
        'target-arrow-color': '#6B7280',
        'source-arrow-color': '#6B7280',
        'width': 2,
        'curve-style': 'bezier',
        'arrow-scale': 0.8,
        'opacity': 1,
        'line-style': 'solid',
      })

      this.hideTooltip()
    }

    private updateUI() {
      const total = this.steps.length
      const pct = total > 1 ? (this.currentIdx / (total - 1)) * 100 : 0

      // 进度条
      if (this.progressFill) this.progressFill.style.width = `${pct}%`
      if (this.thumbEl) this.thumbEl.style.left = `${pct}%`

      // 步骤计数器
      if (this.counterEl) {
        this.counterEl.textContent = `${Math.max(0, this.currentIdx)} / ${total - 1}`
      }

      // 状态信息
      const step = this.currentIdx >= 0 ? this.steps[this.currentIdx] : null
      if (this.msgEl) this.msgEl.textContent = step?.message || '准备就绪 — 点击 ▶ 开始'
      if (this.orderEl) this.orderEl.textContent = step?.order ? `[${step.order.join(', ')}]` : '[ ]'
      if (this.queueEl) this.queueEl.textContent = step?.queue ? `[${step.queue.join(',')}]` : '[ ]'

      // 层级信息格式化
      if (this.levelsEl && step?.levels) {
        const lvls = step.levels
        const groups: Record<number, string[]> = {}
        for (const [node, lvl] of Object.entries(lvls)) {
          if (!groups[lvl]) groups[lvl] = []
          groups[lvl].push(node)
        }
        const parts = Object.entries(groups)
          .sort((a, b) => Number(a[0]) - Number(b[0]))
          .map(([lvl, nds]) => `L${lvl}:[${nds.join(',')}]`)
        this.levelsEl.textContent = parts.join(' ') || '-'
      }

      this.updatePlayButton()
    }

    private updatePlayButton() {
      if (this.iconPlay) this.iconPlay.classList.toggle('hidden', this.isPlaying)
      if (this.iconPause) this.iconPause.classList.toggle('hidden', !this.isPlaying)
    }

    private showTooltip(nodeId: string, text: string) {
      if (!this.tooltipEl) return
      const node = this.cy.getElementById(nodeId)
      if (!node) return
      const pos = node.position()
      const pan = this.cy.pan()
      const zoom = this.cy.zoom()

      const canvasRect = this.cy.container()?.getBoundingClientRect()
      if (!canvasRect) return

      const x = pos.x * zoom + pan.x + canvasRect.width / 2
      const y = pos.y * zoom + pan.y + canvasRect.height / 2

      const ttText = this.tooltipEl.querySelector('.tooltip-text')
      if (ttText) ttText.textContent = text

      this.tooltipEl.hidden = false
      this.tooltipEl.style.left = `${Math.min(x, canvasRect.width - 120)}px`
      this.tooltipEl.style.top = `${Math.max(y - 60, 10)}px`
    }

    private hideTooltip() {
      if (this.tooltipEl) this.tooltipEl.hidden = true
    }
  }

  // ============================================================
  // 初始化
  // ============================================================

  function initGraphViz() {
    const canvasEl = document.getElementById(`${vizId}-canvas`)
    if (!canvasEl) return

    // 构建 Cytoscape 元素数据
    const cyElements = [
      // 节点
      ...nodes.map((n) => ({
        data: { id: n.id, label: n.label || n.id },
        position: n.position || undefined,
      })),
      // 边
      ...edges.map((e) => ({
        data: {
          id: `${e.source}-${e.target}`,
          source: e.source,
          target: e.target,
          label: e.label || '',
          weight: e.weight || 1,
        },
      })),
    ]

    // 创建 Cytoscape 实例
    const cy = cytoscape({
      container: canvasEl,
      elements: cyElements,

      // 布局配置
      layout: {
        name: layout,
        // dagre 特定配置
        ...(layout === 'dagre'
          ? {
              rankDir: 'LR',
              spacingFactor: 80,
              nodeSep: 60,
              rankSep: 80,
            }
          : {}),
        // circle 布局配置
        ...(layout === 'circle'
          ? { radius: 160, startAngle: -90 }
          : {}),
        // breadthfirst 配置
        ...(layout === 'breadthfirst'
          ? { roots: [startNode], directed: false, padding: 40 }
          : {}),
        // grid 配置
        ...(layout === 'grid'
          ? { rows: undefined, cols: undefined, position: () => ({}) }
          : {}),
        animate: false,
        fit: true,
        padding: 30,
      },

      // 样式表 - VisuAlgo 配色方案
      style: [
        // 节点默认样式
        {
          selector: 'node',
          style: {
            'label': 'data(label)',
            'text-valign': 'center',
            'text-halign': 'center',
            'text-wrap': 'nowrap',
            'text-max-width': '60px',
            'text-margin-y': 0,
            'background-color': '#374151',       // 默认深灰
            'border-color': '#4B5563',
            'border-width': 2,
            'color': '#F9FAFB',
            'font-size': '14px',
            'font-weight': '600',
            'width': 40,
            'height': 40,
            'shape': 'ellipse',
            'opacity': 1,
            'overlay-padding': 4,
            'transition-property':
              'background-color, border-color, border-width, width, height, color, opacity',
            'transition-duration': '0.25s',
          },
        },

        // 边默认样式
        {
          selector: 'edge',
          style: {
            'width': 2,
            'line-color': '#6B7280',
            'target-arrow-color': '#6B7280',
            'source-arrow-color': '#6B7280',
            'arrow-scale': 0.8,
            'curve-style': 'bezier',
            'control-point-distances': [0, 0],
            'control-point-weights': [0.25, 0.75],
            'endpoint-z-index-enabled': false,
            'label': 'data(label)',
            'text-rotation': 'autorotate',
            'text-margin-y': -10,
            'font-size': '11px',
            'color': '#9CA3AF',
            'text-background-opacity': 1,
            'text-background-color': '#1F2937',
            'text-background-padding': '3px',
            'text-border-color': transparent,
            'border-style': 'solid',
            'border-opacity': 1,
            'opacity': 1,
            'transition-property':
              'line-color, target-arrow-color, source-arrow-color, width, opacity',
            'transition-duration': '0.25s',
          },
        },

        // 交互态: hover
        {
          selector: 'node:hover',
          style: {
            'border-color': '#60A5FA',
            'border-width': 3,
            'background-color': '#4B5563',
            'cursor': 'pointer',
          },
        },

        // 交互态: selected
        {
          selector: 'node:selected',
          style: {
            'border-color': '#3B82F6',
            'border-width': 3,
            'background-color': '#4B5563',
          },
        },

        // 交互态: edge hover
        {
          selector: 'edge:hover',
          style: {
            'width': 3,
            'line-color': '#93C5FD',
            'target-arrow-color': '#93C5FD',
            'source-arrow-color': '#93C5FD',
            'cursor': 'pointer',
          },
        },
      ],

      // 用户交互选项
      userZoomEnabled: true,
      userPanningEnabled: true,
      boxSelectionEnabled: false,

      // 渲染选项
      minZoom: 0.3,
      maxZoom: 3,
      wheelSensitivity: 0.3,
    })

    // 生成算法步骤并创建动画引擎
    let steps: AnimStep[] = []

    if (algorithm === 'bfs') {
      const graphNodes: GraphNode[] = nodes.map((n) => ({ id: n.id, label: n.label || n.id }))
      const graphEdges: GraphEdge[] = edges.map((e) => ({ source: e.source, target: e.target }))
      steps = generateBFSSteps(graphNodes, graphEdges, startNode)
    }

    // 启动动画引擎
    new GraphAnimationEngine(cy, steps, vizId)
  }

  // DOM 就绪后初始化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGraphViz)
  } else {
    initGraphViz()
  }
</script>

