---
/**
 * ComplexityBadge.astro - 复杂度标签组件
 *
 * 用于显示算法的时间/空间复杂度信息。
 * 提供颜色编码、悬停解释和跳转链接功能。
 *
 * @features
 * - 颜色编码系统（绿/青/黄/红）
 * - 悬停显示详细解释
 * - 可点击跳转到复杂度分析章节
 * - 支持多种复杂度格式（大O、Theta、Omega）
 * - 响应式工具提示
 *
 * @example
 * ```astro
 * <ComplexityBadge
 *   type="time"
 *   value="O(n log n)"
 *   level="good"
 *   description="使用优先队列优化"
 *   href="/algorithms/complexity-analysis"
 * />
 * ```
 */

interface Props {
  /** 复杂度类型：time | space */
  type?: 'time' | 'space';
  /** 复杂度值，如 "O(n log n)" */
  value: string;
  /** 性能等级：excellent | good | moderate | poor */
  level: 'excellent' | 'good' | 'moderate' | 'poor';
  /** 详细描述（悬停显示） */
  description?: string;
  /** 跳转链接 */
  href?: string;
  /** 显示样式：inline | badge | card */
  variant?: 'inline' | 'badge' | 'card';
  /** 是否显示图标 */
  showIcon?: boolean;
  /** 额外的 CSS 类名 */
  class?: string;
}

const {
  type = 'time',
  value,
  level,
  description,
  href,
  variant = 'badge',
  showIcon = true,
  class: className = '',
} = Astro.props;

// 颜色配置
const levelConfig = {
  excellent: {
    color: '#10b981',
    bg: '#ecfdf5',
    border: '#a7f3d0',
    label: '最优',
    icon: '⚡',
  },
  good: {
    color: '#06b6d4',
    bg: '#ecfeff',
    border: '#a5f3fc',
    label: '良好',
    icon: '✓',
  },
  moderate: {
    color: '#f59e0b',
    bg: '#fffbeb',
    border: '#fde68a',
    label: '一般',
    icon: '~',
  },
  poor: {
    color: '#ef4444',
    bg: '#fef2f2',
    border: '#fecaca',
    label: '较差',
    icon: '!',
  },
};

const config = levelConfig[level];

// 类型标签
const typeLabels = {
  time: { label: '时间', icon: '⏱️' },
  space: { label: '空间', icon: '💾' },
};

const typeInfo = typeLabels[type];
---

{variant === 'inline' ? (
  <span class={`complexity-inline ${className}`} data-level={level}>
    <span class="complexity-value">{value}</span>
    {description && (
      <span class="complexity-tooltip" role="tooltip">
        {description}
      </span>
    )}
  </span>
) : variant === 'badge' ? (
  <span class={`complexity-badge ${className}`} data-level={level}>
    {showIcon && (
      <span class="type-icon">{typeInfo.icon}</span>
    )}
    <span class="badge-content">
      <span class="type-label">{typeInfo.label}</span>
      <span
        class="complexity-value"
        style={`color: ${config.color};`}
      >
        {value}
      </span>
    </span>
    <span
      class="level-indicator"
      style={`background: ${config.bg}; color: ${config.color}; border-color: ${config.border};`}
    >
      {config.label}
    </span>

    {/* 悬停提示 */}
    {description && (
      <div class="hover-tooltip" role="tooltip">
        <div class="tooltip-header" style={`background: ${config.color};`}>
          <strong>{value}</strong> - {typeInfo.label}复杂度
        </div>
        <div class="tooltip-body">{description}</div>
        <div class="tooltip-footer">
          <span class="level-badge" style={`background: ${config.color};`}>{config.label}</span>
          <span class="performance-note">性能评级</span>
        </div>
      </div>
    )}
  </span>
) : (
  // 卡片变体
  <div class={`complexity-card ${className}`} data-level={level}>
    <div class="card-header" style={{ background: `linear-gradient(135deg, ${config.bg}, transparent)` }}>
      <div class="header-left">
        {showIcon && <span class="main-icon">{config.icon}</span>}
        <div class="header-text">
          <span class="type-label">{typeInfo.label}复杂度</span>
          <span class="complexity-value-large" style={{ color: config.color }}>
            {value}
          </span>
        </div>
      </div>
      <span
        class="level-badge-large"
        style={{
          background: `linear-gradient(135deg, ${config.color}, ${config.color}dd)`,
        }}
      >
        {config.label}
      </span>
    </div>

    {description && (
      <div class="card-body">
        <p>{description}</p>
      </div>
    )}

    <div class="card-footer">
      <div class="performance-scale">
        {[...Array(4)].map((_, i) => {
          const levels = ['poor', 'moderate', 'good', 'excellent'] as const;
          const currentLevel = levels[i];
          const isActive = currentLevel === level ||
            (levels.indexOf(currentLevel) <= levels.indexOf(level));
          return (
            <div
              class={`scale-bar ${isActive ? 'scale-active' : ''}`}
              style={{
                backgroundColor: isActive ? levelConfig[currentLevel].color : undefined,
                opacity: isActive ? 1 : 0.2,
              }}
              title={levelConfig[currentLevel].label}
            ></div>
          );
        })}
      </div>
      {href && (
        <a href={href} class="learn-more-link">
          了解更多 →
        </a>
      )}
    </div>
  </div>
)}

<style>
  /* ===== 内联变体 ===== */
  .complexity-inline {
    display: inline-flex;
    align-items: center;
    position: relative;
    font-family: var(--font-mono);
    font-weight: var(--font-semibold);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    cursor: default;
  }

  .complexity-inline[data-level="excellent"] {
    color: #10b981;
    background: rgba(16, 185, 129, 0.1);
  }

  .complexity-inline[data-level="good"] {
    color: #06b6d4;
    background: rgba(6, 182, 212, 0.1);
  }

  .complexity-inline[data-level="moderate"] {
    color: #f59e0b;
    background: rgba(245, 158, 11, 0.1);
  }

  .complexity-inline[data-level="poor"] {
    color: #ef4444;
    background: rgba(239, 68, 68, 0.1);
  }

  .complexity-value {
    font-family: var(--font-mono);
  }

  .complexity-tooltip {
    display: none;
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    padding: var(--space-2) var(--space-3);
    background: var(--color-gray-800);
    color: white;
    border-radius: var(--radius-md);
    font-size: var(--text-xs);
    white-space: nowrap;
    z-index: 100;
    box-shadow: var(--shadow-lg);
  }

  .complexity-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: var(--color-gray-800);
  }

  .complexity-inline:hover .complexity-tooltip {
    display: block;
  }

  /* ===== 徽章变体 ===== */
  .complexity-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--bg-subtle);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    position: relative;
    transition: var(--transition-fast);
    cursor: default;
  }

  .complexity-badge:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .type-icon {
    font-size: 1em;
  }

  .badge-content {
    display: flex;
    align-items: baseline;
    gap: var(--space-1);
  }

  .type-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .complexity-value {
    font-family: var(--font-mono);
    font-weight: var(--font-bold);
    font-size: var(--text-sm);
  }

  .level-indicator {
    padding: 2px var(--space-2);
    border-radius: var(--radius-sm);
    font-size: 0.65rem;
    font-weight: var(--font-extrabold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid;
  }

  /* 悬停工具提示 */
  .hover-tooltip {
    display: none;
    position: absolute;
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    width: 280px;
    background: white;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    overflow: hidden;
    z-index: 200;
    animation: fadeInUp 0.2s ease-out;
  }

  .complexity-badge:hover .hover-tooltip {
    display: block;
  }

  .tooltip-header {
    padding: var(--space-3) var(--space-4);
    color: white;
    font-size: var(--text-sm);
  }

  .tooltip-body {
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-xs);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .tooltip-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    background: var(--bg-subtle);
    border-top: 1px solid var(--border-default);
  }

  .level-badge {
    padding: 2px var(--space-2);
    border-radius: var(--radius-sm);
    color: white;
    font-size: 0.65rem;
    font-weight: var(--font-bold);
    text-transform: uppercase;
  }

  .performance-note {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  /* ===== 卡片变体 ===== */
  .complexity-card {
    background: var(--bg-base);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: var(--transition-normal);
    max-width: 320px;
  }

  .complexity-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-4) var(--space-5);
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .main-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-lg);
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xl);
    box-shadow: var(--shadow-sm);
  }

  .header-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .complexity-value-large {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
  }

  .level-badge-large {
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    color: white;
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-body {
    padding: 0 var(--space-5) var(--space-4);
  }

  .card-body p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .card-footer {
    padding: var(--space-3) var(--space-5);
    background: var(--bg-subtle);
    border-top: 1px solid var(--border-default);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .performance-scale {
    display: flex;
    gap: 3px;
  }

  .scale-bar {
    width: 24px;
    height: 6px;
    border-radius: 3px;
    background: var(--border-default);
    transition: var(--transition-fast);
  }

  .scale-active {
    box-shadow: 0 0 8px currentColor;
  }

  .learn-more-link {
    font-size: var(--text-xs);
    color: var(--color-primary-500);
    font-weight: var(--font-semibold);
    text-decoration: none;
    transition: var(--transition-fast);
  }

  .learn-more-link:hover {
    color: var(--color-primary-700);
  }
</style>
