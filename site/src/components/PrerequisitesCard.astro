---
/**
 * PrerequisitesCard.astro - 前置知识卡片组件
 *
 * 用于显示学习当前章节所需的前置知识，
 * 帮助读者评估自己是否具备足够的背景知识。
 *
 * @features
 * - 知识点列表 + 链接
 * - 掌握程度自测（复选框）
 * - 学习路径建议
 * - 可视化依赖关系图
 *
 * @example
 * ```astro
 * <PrerequisitesCard
 *   title="学习 Dijkstra 算法前需要掌握"
 *   items={[
 *     { title: "图的基本概念", url: "/core-concepts/data-types", required: true },
 *     { title: "队列与优先队列", url: "/core-concepts/traits", required: true },
 *     { title: "贪心算法思想", url: "/algorithms/other", required: false }
 *   ]}
 * />
 * ```
 */

interface Props {
  /** 卡片标题 */
  title?: string;
  /** 前置知识列表 */
  items: Array<{
    /** 知识点名称 */
    title: string;
    /** 链接地址 */
    url?: string;
    /** 是否为必须掌握的知识 */
    required?: boolean;
    /** 简要描述 */
    description?: string;
    /** 预计学习时间 */
    estimatedTime?: string;
  }>;
  /** 是否显示学习路径建议 */
  showLearningPath?: boolean;
  /** 额外的 CSS 类名 */
  class?: string;
}

const {
  title = '前置知识',
  items,
  showLearningPath = true,
  class: className = '',
} = Astro.props;

const requiredItems = items.filter(item => item.required);
const optionalItems = items.filter(item => !item.required);

// 计算总预计时间
const totalTime = items
  .filter(item => item.estimatedTime)
  .reduce((acc, item) => acc + (parseInt(item.estimatedTime!) || 0), 0);
---

<div class={`prerequisites-card ${className}`}>
  <div class="prereq-header">
    <div class="header-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
        <polyline points="22,4 12,14.01 9,11.01"/>
      </svg>
    </div>
    <div class="header-text">
      <h3 class="prereq-title">{title}</h3>
      <p class="prereq-subtitle">
        共 <strong>{items.length}</strong> 个知识点
        {totalTime > 0 && ` · 预计 ${totalTime} 分钟`}
      </p>
    </div>
  </div>

  <div class="prereq-body">
    {/* 必须掌握 */}
    {requiredItems.length > 0 && (
      <div class="knowledge-section">
        <h4 class="section-title section-title--required">
          <span class="required-indicator">必须掌握</span>
          ({requiredItems.length} 项)
        </h4>
        <ul class="knowledge-list">
          {requiredItems.map((item) => (
            <li class="knowledge-item knowledge-item--required">
              <label class="item-checkbox">
                <input type="checkbox" data-item={item.title} />
                <span class="checkmark"></span>
              </label>
              <div class="item-content">
                <div class="item-header">
                  {item.url ? (
                    <a href={item.url} class="item-title-link">{item.title}</a>
                  ) : (
                    <span class="item-title">{item.title}</span>
                  )}
                  {item.estimatedTime && (
                    <span class="time-badge">{item.estimatedTime}分钟</span>
                  )}
                </div>
                {item.description && (
                  <p class="item-description">{item.description}</p>
                )}
              </div>
            </li>
          ))}
        </ul>
      </div>
    )}

    {/* 推荐了解 */}
    {optionalItems.length > 0 && (
      <details class="knowledge-section details-optional">
        <summary>
          <h4 class="section-title">
            <span class="optional-indicator">推荐了解</span>
            ({optionalItems.length} 项)
          </h4>
        </summary>
        <ul class="knowledge-list">
          {optionalItems.map((item) => (
            <li class="knowledge-item knowledge-item--optional">
              <label class="item-checkbox">
                <input type="checkbox" data-item={item.title} />
                <span class="checkmark"></span>
              </label>
              <div class="item-content">
                <div class="item-header">
                  {item.url ? (
                    <a href={item.url} class="item-title-link">{item.title}</a>
                  ) : (
                    <span class="item-title">{item.title}</span>
                  )}
                  {item.estimatedTime && (
                    <span class="time-badge">{item.estimatedTime}分钟</span>
                  )}
                </div>
                {item.description && (
                  <p class="item-description">{item.description}</p>
                )}
              </div>
            </li>
          ))}
        </ul>
      </details>
    )}

    {/* 学习进度 */}
    <div class="progress-section">
      <div class="progress-header">
        <span class="progress-label">我的掌握情况</span>
        <span class="progress-text" id="progress-text">0 / {items.length} 已完成</span>
      </div>
      <div class="progress-bar-container">
        <div class="progress-bar-fill" id="progress-fill" style="width: 0%"></div>
      </div>
    </div>

    {/* 学习路径建议 */}
    {showLearningPath && (
      <div class="learning-path">
        <h4 class="path-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="20" x2="12" y2="10"/>
            <line x1="18" y1="20" x2="18" y2="4"/>
            <line x1="6" y1="20" x2="6" y2="16"/>
          </svg>
          学习路径建议
        </h4>
        <ol class="path-steps">
          {items.map((item, index) => (
            <li class={`path-step ${index === 0 ? 'path-step--first' : ''}`}>
              <div class="step-marker"></div>
              <div class="step-content">
                {item.url ? (
                  <a href={item.url} class="step-link">{item.title}</a>
                ) : (
                  <span>{item.title}</span>
                )}
                {index < items.length - 1 && (
                  <svg class="step-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="6,9 12,15 18,9"/>
                  </svg>
                )}
              </div>
            </li>
          ))}
        </ol>
      </div>
    )}
  </div>

  <div class="prereq-footer">
    <button class="reset-progress-btn" id="reset-prereq-btn">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="1,4 1,10 7,10"/>
        <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
      </svg>
      重置进度
    </button>
  </div>
</div>

<style>
  .prerequisites-card {
    margin: var(--space-6) 0;
    background: var(--bg-base);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  /* ===== 头部 ===== */
  .prereq-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background: linear-gradient(135deg, #ecfdf5 0%, #f0fdf4 50%, #ffffff 100%);
    border-bottom: 1px solid var(--color-success-200);
  }

  .header-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-lg);
    background: white;
    color: var(--color-success-600);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
  }

  .header-text {
    flex: 1;
  }

  .prereq-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin: 0 0 var(--space-1) 0;
  }

  .prereq-subtitle {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  /* ===== 主体 ===== */
  .prereq-body {
    padding: var(--space-6);
  }

  /* 知识区域 */
  .knowledge-section {
    margin-bottom: var(--space-5);
  }

  .details-optional {
    margin: 0;
    border: none;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-subtle);
  }

  .details-optional summary {
    padding: var(--space-3) var(--space-4);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: transparent;
  }

  .details-optional summary::-webkit-details-marker {
    display: none;
  }

  .details-optional[open] summary {
    border-bottom: 1px solid var(--border-default);
    margin-bottom: var(--space-3);
  }

  .section-title {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--text-secondary);
    margin: 0 0 var(--space-3) 0;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .required-indicator,
  .optional-indicator {
    padding: 2px var(--space-2);
    border-radius: var(--radius-sm);
    font-size: 0.7rem;
    font-weight: var(--font-bold);
    text-transform: uppercase;
  }

  .required-indicator {
    background: var(--color-danger-50);
    color: var(--color-danger-600);
  }

  .optional-indicator {
    background: var(--color-info-50);
    color: var(--color-info-600);
  }

  /* 知识列表 */
  .knowledge-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .knowledge-item {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--bg-base);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    transition: var(--transition-fast);
    align-items: flex-start;
  }

  .knowledge-item:hover {
    border-color: var(--color-primary-200);
    box-shadow: var(--shadow-sm);
  }

  .knowledge-item--required {
    border-left: 3px solid var(--color-danger-500);
  }

  .knowledge-item--optional {
    border-left: 3px solid var(--color-info-500);
  }

  /* 自定义复选框 */
  .item-checkbox {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    cursor: pointer;
  }

  .item-checkbox input {
    position: absolute;
    opacity: 0;
    width: 20px;
    height: 20px;
    cursor: pointer;
  }

  .checkmark {
    width: 20px;
    height: 20px;
    border: 2px solid var(--color-primary-300);
    border-radius: var(--radius-sm);
    background: var(--bg-base);
    transition: var(--transition-fast);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .checkmark::after {
    content: '';
    width: 5px;
    height: 10px;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg) scale(0);
    transition: transform var(--duration-fast) var(--ease-spring);
  }

  .item-checkbox input:checked ~ .checkmark {
    background: var(--gradient-primary);
    border-color: var(--color-primary-500);
  }

  .item-checkbox input:checked ~ .checkmark::after {
    transform: rotate(45deg) scale(1);
  }

  .item-checkbox input:focus-visible ~ .checkmark {
    outline: 2px solid var(--color-primary-500);
    outline-offset: 2px;
  }

  /* 内容区 */
  .item-content {
    flex: 1;
    min-width: 0;
  }

  .item-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .item-title,
  .item-title-link {
    font-weight: var(--font-medium);
    color: var(--text-primary);
    font-size: var(--text-sm);
  }

  .item-title-link {
    color: var(--color-primary-600);
    text-decoration: none;
    transition: var(--transition-fast);
  }

  .item-title-link:hover {
    color: var(--color-primary-800);
    text-decoration: underline;
  }

  .time-badge {
    padding: 2px var(--space-2);
    background: var(--color-gray-100);
    border-radius: var(--radius-sm);
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .item-description {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin: var(--space-1) 0 0 0;
    line-height: var(--leading-relaxed);
  }

  /* 进度条 */
  .progress-section {
    margin-top: var(--space-5);
    padding-top: var(--space-5);
    border-top: 1px dashed var(--border-default);
  }

  .progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-2);
  }

  .progress-label {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-secondary);
  }

  .progress-text {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .progress-bar-container {
    height: 8px;
    background: var(--bg-muted);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    background: var(--gradient-primary);
    border-radius: var(--radius-full);
    transition: width var(--duration-normal) var(--ease-spring);
  }

  /* 学习路径 */
  .learning-path {
    margin-top: var(--space-5);
    padding-top: var(--space-5);
    border-top: 1px dashed var(--border-default);
  }

  .path-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--text-secondary);
    margin: 0 0 var(--space-4) 0;
  }

  .path-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    padding-left: var(--space-6);
  }

  .path-steps::before {
    content: '';
    position: absolute;
    left: 11px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: linear-gradient(to bottom, var(--color-primary-300), var(--color-cyan-300));
    opacity: 0.3;
  }

  .path-step {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    position: relative;
    padding: var(--space-2) 0;
  }

  .step-marker {
    position: absolute;
    left: calc(-1 * var(--space-6) + 4px);
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--gradient-primary);
    border: 2px solid white;
    box-shadow: var(--shadow-sm);
    z-index: 1;
  }

  .path-step--first .step-marker {
    box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.2);
  }

  .step-content {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
  }

  .step-link {
    color: var(--color-primary-600);
    text-decoration: none;
    font-weight: var(--font-medium);
  }

  .step-link:hover {
    color: var(--color-primary-800);
    text-decoration: underline;
  }

  .step-arrow {
    color: var(--color-primary-300);
    flex-shrink: 0;
  }

  /* ===== 底部 ===== */
  .prereq-footer {
    padding: var(--space-3) var(--space-6);
    background: var(--bg-subtle);
    border-top: 1px solid var(--border-default);
    text-align: right;
  }

  .reset-progress-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    cursor: pointer;
    font-size: var(--text-xs);
    transition: var(--transition-fast);
  }

  .reset-progress-btn:hover {
    background: var(--bg-base);
    color: var(--text-primary);
    border-color: var(--color-primary-300);
  }

  /* ===== 响应式 ===== */
  @media (max-width: 768px) {
    .prereq-header {
      flex-direction: column;
      text-align: center;
      gap: var(--space-3);
    }

    .knowledge-item {
      flex-direction: column;
      gap: var(--space-2);
    }

    .path-steps {
      padding-left: var(--space-5);
    }
  }
</style>

<script define:vars={{ totalItems: items.length }}>
  document.addEventListener('DOMContentLoaded', () => {
    const checkboxes = document.querySelectorAll('.prerequisites-card input[type="checkbox"]');
    const progressFill = document.getElementById('progress-fill');
    const progressText = document.getElementById('progress-text');
    const resetBtn = document.getElementById('reset-prereq-btn');

    function updateProgress() {
      const checked = document.querySelectorAll('.prerequisites-card input[type="checkbox"]:checked').length;
      const percentage = (checked / totalItems) * 100;

      if (progressFill) {
        progressFill.style.width = `${percentage}%`;
      }
      if (progressText) {
        progressText.textContent = `${checked} / ${totalItems} 已完成`;
      }
    }

    checkboxes.forEach(checkbox => {
      checkbox.addEventListener('change', updateProgress);
    });

    resetBtn?.addEventListener('click', () => {
      checkboxes.forEach(cb => cb.checked = false);
      updateProgress();
    });
  });
</script>
