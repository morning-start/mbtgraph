#!/bin/sh
#
# mbtgraph pre-commit hook
#
# Steps:
#   0. Security scan  — detect secrets/credentials in staged files
#   1. moon fmt        — format .mbt code
#   2. moon info       — update .mbti interface files
#   3. moon check      — compile check
#

set -e

# ============================================================
# Step 0: Security Scan — silent on pass, loud on fail
# ============================================================

STAGED_ALL=$(git diff-index --cached --name-only --diff-filter=ACM HEAD 2>/dev/null | grep -v '^\.githooks/' || true)

if [ -n "$STAGED_ALL" ]; then
    FOUND=0
    MATCH_LINES=""

    # Extract added lines from staged diff (exclude .githooks/ to avoid self-match)
    DIFF_LINES=$(git diff-index --cached -p HEAD -- . ':(exclude).githooks/' 2>/dev/null | grep "^+" | grep -v "^+++" || true)

    # AWS Access Key ID (AKIA + 16 uppercase alphanum)
    if echo "$DIFF_LINES" | grep -qE 'AKIA[0-9A-Z]{16}' 2>/dev/null; then
        FOUND=1; MATCH_LINES="${MATCH_LINES}\n  - AWS Access Key ID (AKIA...)"
    fi

    # Private key (PEM format)
    if echo "$DIFF_LINES" | grep -qE '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----' 2>/dev/null; then
        FOUND=1; MATCH_LINES="${MATCH_LINES}\n  - Private Key (BEGIN ... PRIVATE KEY)"
    fi

    # Password hardcoded: password/pwd/passwd = "..."
    if echo "$DIFF_LINES" | grep -qiE '(password|passwd|pwd)\s*[:=]\s*['\''"][^\x27\x22]{4,}['\''"]' 2>/dev/null; then
        FOUND=1; MATCH_LINES="${MATCH_LINES}\n  - Password hardcoded in code"
    fi

    # Generic secret / API key / token assignment with long value
    if echo "$DIFF_LINES" | grep -qiE '(secret|api_key|apikey|access_token|auth_token|private_token)\s*[:=]\s*['\''"][A-Za-z0-9]{15,}['\''"]' 2>/dev/null; then
        FOUND=1; MATCH_LINES="${MATCH_LINES}\n  - Secret/API Key/Token hardcoded"
    fi

    # GitHub tokens (ghp, gho, ghu, ghs, ghr)
    if echo "$DIFF_LINES" | grep -qE 'gh[pouhs]_[A-Za-z0-9]{30,}' 2>/dev/null; then
        FOUND=1; MATCH_LINES="${MATCH_LINES}\n  - GitHub token detected"
    fi

    # Stripe live keys
    if echo "$DIFF_LINES" | grep -qE 'sk_live_|pk_live_' 2>/dev/null; then
        FOUND=1; MATCH_LINES="${MATCH_LINES}\n  - Stripe live key detected"
    fi

    # Database connection strings with embedded credentials
    if echo "$DIFF_LINES" | grep -qiE '(mongodb(\+srv)?|mysql|postgres|redis)://[^/\s]+:[^/\s]+@' 2>/dev/null; then
        FOUND=1; MATCH_LINES="${MATCH_LINES}\n  - Database connection string with password"
    fi

    # Google API key
    if echo "$DIFF_LINES" | grep -qE 'AIza[0-9A-Z_-]{35}' 2>/dev/null; then
        FOUND=1; MATCH_LINES="${MATCH_LINES}\n  - Google API key detected"
    fi

    # Slack tokens
    if echo "$DIFF_LINES" | grep -qE 'xox[baprs]-' 2>/dev/null; then
        FOUND=1; MATCH_LINES="${MATCH_LINES}\n  - Slack token detected"
    fi

    # JWT token (base64url.header.payload.signature)
    if echo "$DIFF_LINES" | grep -qE 'eyJ[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+' 2>/dev/null; then
        FOUND=1; MATCH_LINES="${MATCH_LINES}\n  - JWT token detected"
    fi

    if [ "$FOUND" = "1" ]; then
        echo ""
        echo "============================================"
        echo "  SECURITY WARNING: Potential secrets detected!"
        echo "============================================"
        echo -e "The following patterns were found in staged changes:${MATCH_LINES}"
        echo ""
        echo "  Please:"
        echo "  1. Remove or replace secrets with environment variables"
        echo "  2. Use .gitignore to exclude credential files (.env etc.)"
        echo "  3. If false positive, use --no-verify to bypass"
        echo "============================================"
        exit 1
    fi
fi

# ============================================================
# Step 1-3: MoonBit toolchain checks (only when .mbt staged)
# ============================================================

STAGED_MBT=$(git diff-index --cached --name-only --diff-filter=ACM HEAD 2>/dev/null | grep '\.mbt$' || true)

if [ -z "$STAGED_MBT" ]; then
    exit 0
fi

echo "[pre-commit] Detected staged .mbt files, running MoonBit checks..."

# Step 1: Format code
echo "[pre-commit] Running moon fmt..."
if ! moon fmt 2>&1; then
    echo ""; echo "ERROR: moon fmt failed!"; echo "Commit aborted."; exit 1
fi

FORMAT_CHANGED=$(git diff --name-only -- '*.mbt' 2>/dev/null || true)
if [ -n "$FORMAT_CHANGED" ]; then
    echo "[pre-commit] Re-staging formatted files..."
    git add $FORMAT_CHANGED
fi

# Step 2: Update interfaces
echo "[pre-commit] Running moon info..."
if ! moon info 2>&1; then
    echo ""; echo "ERROR: moon info failed!"; echo "Commit aborted."; exit 1
fi

MBTI_CHANGED=$(git diff --name-only -- '*.mbti' 2>/dev/null || true)
if [ -n "$MBTI_CHANGED" ]; then
    echo "[pre-commit] Staging updated .mbti files..."
    git add $MBTI_CHANGED
fi

# Step 3: Compile check
echo "[pre-commit] Running moon check..."
if ! moon check 2>&1; then
    echo ""; echo "ERROR: moon check failed!"; echo "Commit aborted."; exit 1
fi

echo "[pre-commit] All checks passed (security + fmt + info + check)."
exit 0
